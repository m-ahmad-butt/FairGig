            "url": {
              "raw": "{{baseUrl}}/api/users/public/:email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "public", ":email"],
              "variable": [{"key": "email", "value": "l233059@lhr.nu.edu.pk"}]
            }
          }
        },
        {
          "name": "Get Reputation",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
