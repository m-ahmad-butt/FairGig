            "url": {
              "raw": "{{baseUrl}}/api/admin/users/:email/toggle-ban",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", ":email", "toggle-ban"],
              "variable": [{"key": "email", "value": "user@nu.edu.pk"}]
