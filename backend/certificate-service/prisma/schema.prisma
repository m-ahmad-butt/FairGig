generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model HealthPing {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  service   String
  createdAt DateTime @default(now())
}
