generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model HealthPing {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  service   String
  createdAt DateTime @default(now())
}

model WorkSession {
  id              String    @id @default(uuid()) @map("_id")
  worker_id       String
  platform        String
  session_date    DateTime
  start_time      DateTime
  end_time        DateTime
  hours_worked    Float
  trips_completed Int
  created_at      DateTime  @default(now())
  earnings        Earning[]

  @@index([worker_id])
  @@index([session_date])
  @@unique([worker_id, session_date])
  @@map("work_sessions")
}

model Earning {
  id           String      @id @default(uuid()) @map("_id")
  session_id   String
  gross_amount Float
  created_at   DateTime    @default(now())
  session      WorkSession @relation(fields: [session_id], references: [id])

  @@index([session_id])
  @@map("earnings")
}
